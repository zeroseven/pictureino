#!/usr/bin/env bash

## Description: Run tests and static analysis
## Usage: test [flags]
## Example: "ddev test" or "ddev test --sca" or "ddev test --lint"
## ProjectTypes: typo3
## ExecRaw: true

set -Eeuo pipefail

if [ -z "${IS_DDEV_PROJECT:-}" ]; then
    if command -v ddev >/dev/null 2>&1 && [ -d ".ddev" ]; then
        ddev exec /var/www/html/.ddev/commands/web/test "$@"
        exit $?
    fi
fi

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; BLUE='\033[0;34m'; NC='\033[0m'
info()   { echo -e "${YELLOW}$*${NC}"; }
ok()     { echo -e "${GREEN}✓ $*${NC}"; }
err()    { echo -e "${RED}✗ $*${NC}"; }
header() { echo -e "${BLUE}━━━ $* ━━━${NC}"; }

FILTER=""
RUN_UNIT=false
RUN_SCA=false
RUN_LINT=false

for arg in "$@"; do
    case $arg in
        --filter=*) FILTER="${arg#*=}"; RUN_UNIT=true ;;
        --sca)      RUN_SCA=true ;;
        --lint)     RUN_LINT=true ;;
        --all)      RUN_UNIT=true; RUN_SCA=true; RUN_LINT=true ;;
        --help|-h)
            echo "Usage: ddev test [flags]"
            echo "      --filter=EXPR    PHPUnit --filter expression"
            echo "      --sca            Run PHPStan static analysis"
            echo "      --lint           Run php-cs-fixer lint (dry-run)"
            echo "      --all            Run all checks (lint + sca + unit)"
            echo ""
            echo "Without flags: runs unit tests only"
            exit 0
            ;;
    esac
done

# Default: run unit tests if no specific flag given
if ! $RUN_UNIT && ! $RUN_SCA && ! $RUN_LINT; then
    RUN_UNIT=true
fi

echo ""; header "Pictureino Test Runner"; echo ""

header "Readiness: Dependencies"
if [ ! -f "/var/www/html/.build/vendor/autoload.php" ]; then
    info "vendor not found — running composer install..."
    cd /var/www/html && composer install --no-interaction --no-progress
    ok "Dependencies installed"
else
    ok "Dependencies ready"
fi

PASS=true

if $RUN_LINT; then
    header "php-cs-fixer (dry-run)"
    if /var/www/html/.build/bin/php-cs-fixer fix --dry-run --diff 2>&1; then
        ok "Code style OK"
    else
        err "Code style issues found"; PASS=false
    fi
fi

if $RUN_SCA; then
    header "PHPStan"
    if /var/www/html/.build/bin/phpstan analyse -c /var/www/html/phpstan.neon 2>&1; then
        ok "Static analysis OK"
    else
        err "PHPStan errors found"; PASS=false
    fi
fi

if $RUN_UNIT; then
    header "PHPUnit"
    PHPUNIT_ARGS=""
    [ -n "$FILTER" ] && PHPUNIT_ARGS="--filter=$FILTER"
    if /var/www/html/.build/bin/phpunit -c /var/www/html/phpunit.unit.xml $PHPUNIT_ARGS 2>&1; then
        ok "Unit tests passed"
    else
        err "Unit tests failed"; PASS=false
    fi
fi

echo ""
if $PASS; then
    echo -e "${GREEN}✓ All checks passed${NC}"
else
    echo -e "${RED}✗ Some checks failed${NC}"; exit 1
fi
